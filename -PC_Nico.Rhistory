#| label: Simulating tracks
#| echo: TRUE
#| message: FALSE
#| warning: FALSE
#| code-fold: TRUE
#| cache: TRUE
#| dependson: c("Simulating tracks")
## Writing a function to create some noise ####
noise_track <- function(track,
sd_time,
sd_space,
p_drop) {
n <- nrow(track)
## a) Jitter time
time_jitter <- rnorm(n, mean = 0, sd = sd_time)
track$time <- track$time + time_jitter
## b) Jitter space (bivariate normal, independent x/y)
track$x <- track$x + rnorm(n, mean = 0, sd = sd_space)
track$y <- track$y + rnorm(n, mean = 0, sd = sd_space)
## c) Randomly delete locations
keep <- runif(n) > p_drop
track <- track[keep, ]
rownames(track) <- NULL
track
}
## Running the function to obtain the final track ####
final_tracks <- noise_track(tracks,
sd_time = 30,
sd_space = 10,
p_drop = 0.02)
nrow(tracks)
nrow(final_tracks)
## Store the simulated data ####
saveRDS(final_tracks, file = here("Data", "Movement_Data", "Chamois_Tracks.rds"))
library(nlme)
set.seed(42)
# Parameters for the sigmoid growth curve
Asym_true <- 20
xmid_true <- 5
scal_true <- 1.5
# Random effect per plot for Asym
plot_effect <- rnorm(3, 0, 2)
data <- data.frame()
for (i in 1:3) {
time <- seq(0, 10, by = 1)
height <- (Asym_true + plot_effect[i]) / (1 + exp(-(time - xmid_true)/scal_true)) +
rnorm(length(time), 0, 0.5)  # residual error
data <- rbind(data, data.frame(plot = factor(i), time = time, height = height))
}
head(data)
# Fit a logistic growth curve with random Asym per plot
fit <- nlme(
height ~ Asym / (1 + exp(-(time - xmid)/scal)),
data = data,
fixed = Asym + xmid + scal ~ 1,         # fixed effects to estimate
random = Asym ~ 1 | plot,               # random effect on Asym by plot
start = c(Asym = 18, xmid = 5, scal = 1)  # starting guesses
)
summary(fit)
library(ggplot2)
data$pred <- predict(fit)
ggplot(data, aes(time, height, color = plot)) +
geom_point() +
geom_line(aes(y = pred)) +
theme_minimal()
# cloglog transform
cloglog <- function(p) log(-log(1 - p))
# inverse cloglog
inv_cloglog <- function(eta) 1 - exp(-exp(eta))
# Example
p <- 0.5
eta <- cloglog(p)       # transform
p_back <- inv_cloglog(eta)  # back to probability
eta
p_back
